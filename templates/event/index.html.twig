{% extends 'base.html.twig' %}

{% block title %}Événements — Eventix{% endblock %}

{% block body %}

<section style="background:linear-gradient(135deg,#3b28cc,#2d1fa3);padding:4rem 0 3rem;color:#fff;">
    <div class="container">
        <h1 style="font-size:2.5rem;font-weight:800;margin-bottom:0.5rem;">Tous les événements</h1>
        <p style="opacity:0.8;font-size:1rem;">Découvrez et réservez les meilleurs événements</p>
    </div>
</section>

<section style="padding:4rem 0;">
    <div class="container">
        {% if events|length == 0 %}
        <div style="text-align:center;padding:4rem 0;">
            <i class="bi bi-calendar-x" style="font-size:4rem;color:#d1d5db;display:block;margin-bottom:1.5rem;"></i>
            <h3 style="color:#6b7280;font-weight:600;">Aucun événement disponible</h3>
            <p style="color:#9ca3af;">Revenez bientôt pour découvrir nos prochains événements.</p>
        </div>
        {% else %}
        <div class="row g-4">
            {% for event in events %}
            <div class="col-md-6 col-lg-4">
                <div class="event-card">
                    {% if event.image %}
                        <img src="{{ event.image }}" alt="{{ event.title }}" class="event-card-img">
                    {% else %}
                        <div class="event-card-img-placeholder"><i class="bi bi-calendar-event"></i></div>
                    {% endif %}
                    <div class="event-card-body">
                        <span class="event-badge"><i class="bi bi-calendar3 me-1"></i>{{ event.date|date('d M Y') }}</span>
                        <h3 class="event-title">{{ event.title }}</h3>
                        <p class="event-meta"><i class="bi bi-geo-alt-fill"></i>{{ event.location }}</p>
                        <p class="event-meta"><i class="bi bi-clock"></i>{{ event.date|date('H:i') }}</p>
                        <p style="font-size:0.88rem;color:#6b7280;margin-bottom:1rem;line-height:1.6;">
                            {{ event.description|slice(0,100) }}{% if event.description|length > 100 %}...{% endif %}
                        </p>
                        <div style="display:flex;justify-content:space-between;align-items:center;">
                            {% set avail = event.availableSeats %}
                            <span class="seats-badge {{ avail <= 0 ? 'full' : (avail <= 5 ? 'low' : '') }}">
                                <i class="bi bi-ticket me-1"></i>{{ avail <= 0 ? 'Complet' : avail ~ ' places' }}
                            </span>
                            <a href="{{ path('app_event_show', {id: event.id}) }}"
                               class="btn-primary-eventix {{ avail <= 0 ? 'disabled' : '' }}"
                               style="padding:0.45rem 1.2rem;font-size:0.85rem;{{ avail <= 0 ? 'opacity:0.5;pointer-events:none;' : '' }}">
                                {{ avail <= 0 ? 'Complet' : 'Réserver' }}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
</section>

{% endblock %}
