{% extends 'base.html.twig' %}

{% block title %}Eventix — Réservation d'Événements{% endblock %}

{% block body %}

{# HERO #}
<section style="background:linear-gradient(135deg,#f8f8fc 0%,#eeeeff 100%);padding:5rem 0 4rem;overflow:hidden;">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div style="display:inline-block;background:#fff;border-radius:50px;padding:0.4rem 1rem;margin-bottom:1.2rem;box-shadow:0 2px 12px rgba(59,40,204,0.1);">
                    <span style="color:#3b28cc;font-weight:700;font-size:0.8rem;letter-spacing:1px;">🎉 PROCHAIN ÉVÉNEMENT</span>
                </div>
                <h1 style="font-size:clamp(2rem,5vw,3rem);font-weight:800;color:#1a1a2e;line-height:1.15;margin-bottom:0.8rem;">
                    {% if events|length > 0 %}{{ events[0].title }}{% else %}Summit 2026{% endif %}
                </h1>
                <p style="color:#3b28cc;font-weight:700;font-size:1.05rem;margin-bottom:1rem;">
                    Shaping the Future of Innovation
                </p>
                <p style="color:#4b5563;font-size:0.97rem;line-height:1.7;margin-bottom:1.8rem;max-width:480px;">
                    Rejoignez des leaders du secteur, des innovateurs et des visionnaires pour des discussions de pointe, des opportunités de networking et des insights transformateurs.
                </p>
                {% if events|length > 0 %}
                <div style="display:flex;flex-direction:column;gap:0.6rem;margin-bottom:1.8rem;">
                    <div style="display:flex;align-items:center;gap:0.6rem;color:#4b5563;font-size:0.93rem;">
                        <i class="bi bi-calendar3" style="color:#3b28cc;"></i>
                        {{ events[0].date|date('d F Y à H:i') }}
                    </div>
                    <div style="display:flex;align-items:center;gap:0.6rem;color:#4b5563;font-size:0.93rem;">
                        <i class="bi bi-geo-alt" style="color:#3b28cc;"></i>
                        {{ events[0].location }}
                    </div>
                    <div style="display:flex;align-items:center;gap:0.6rem;color:#4b5563;font-size:0.93rem;">
                        <i class="bi bi-people" style="color:#3b28cc;"></i>
                        {{ events[0].seats }}+ places disponibles
                    </div>
                </div>
                {% endif %}
                <div style="display:flex;gap:1rem;flex-wrap:wrap;">
                    <a href="{{ path('app_events') }}" class="btn-primary-eventix" style="text-transform:uppercase;letter-spacing:0.8px;font-size:0.85rem;">
                        RÉSERVER MAINTENANT
                    </a>
                    <a href="{{ path('app_events') }}" class="btn-outline-eventix">
                        Voir les événements
                    </a>
                </div>
            </div>

            <div class="col-lg-6 position-relative">
                <div style="border-radius:20px;overflow:hidden;box-shadow:0 24px 64px rgba(59,40,204,0.15);position:relative;">
                    {% if events|length > 0 and events[0].image %}
                        <img src="{{ events[0].image }}" alt="{{ events[0].title }}" style="width:100%;height:420px;object-fit:cover;display:block;">
                    {% else %}
                        <div style="width:100%;height:420px;background:linear-gradient(135deg,#1a1a2e 0%,#3b28cc 60%,#00b4d8 100%);display:flex;align-items:center;justify-content:center;">
                            <i class="bi bi-calendar-event" style="font-size:5rem;color:rgba(255,255,255,0.3);"></i>
                        </div>
                    {% endif %}
                </div>
                <div style="position:absolute;top:20px;right:-10px;" class="feature-pill d-none d-xl-flex">
                    <i class="bi bi-person-badge"></i> Speakers Premium
                </div>
                <div style="position:absolute;top:85px;right:-10px;" class="feature-pill d-none d-xl-flex">
                    <i class="bi bi-wifi"></i> Live Streaming
                </div>
                <div style="position:absolute;top:150px;right:-10px;" class="feature-pill d-none d-xl-flex">
                    <i class="bi bi-gift"></i> Networking Events
                </div>
            </div>
        </div>

        {# COUNTDOWN #}
        {% if events|length > 0 %}
        <div style="margin-top:3rem;">
            <p style="font-size:0.9rem;font-weight:600;color:#4b5563;margin-bottom:1rem;">L'événement commence dans :</p>
            <div style="display:flex;gap:1rem;flex-wrap:wrap;" id="countdown-wrap">
                <div class="countdown-box"><div class="countdown-num" id="cd-days">--</div><div class="countdown-label">JOURS</div></div>
                <div class="countdown-box"><div class="countdown-num" id="cd-hours">--</div><div class="countdown-label">HEURES</div></div>
                <div class="countdown-box"><div class="countdown-num" id="cd-mins">--</div><div class="countdown-label">MINUTES</div></div>
                <div class="countdown-box"><div class="countdown-num" id="cd-secs">--</div><div class="countdown-label">SECONDES</div></div>
            </div>
        </div>
        {% endif %}
    </div>
</section>

{# STATS #}
<section style="background:#fff;padding:2.5rem 0;border-top:1px solid #f0f0f8;border-bottom:1px solid #f0f0f8;">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-6 col-md-3">
                <div style="font-size:2rem;font-weight:800;color:#3b28cc;">{{ events|length }}+</div>
                <div style="color:#6b7280;font-size:0.9rem;font-weight:500;">Événements</div>
            </div>
            <div class="col-6 col-md-3">
                <div style="font-size:2rem;font-weight:800;color:#3b28cc;">5000+</div>
                <div style="color:#6b7280;font-size:0.9rem;font-weight:500;">Participants</div>
            </div>
            <div class="col-6 col-md-3">
                <div style="font-size:2rem;font-weight:800;color:#3b28cc;">50+</div>
                <div style="color:#6b7280;font-size:0.9rem;font-weight:500;">Speakers</div>
            </div>
            <div class="col-6 col-md-3">
                <div style="font-size:2rem;font-weight:800;color:#3b28cc;">3</div>
                <div style="color:#6b7280;font-size:0.9rem;font-weight:500;">Jours</div>
            </div>
        </div>
    </div>
</section>

{# EVENTS PREVIEW #}
{% if events|length > 0 %}
<section style="padding:5rem 0;background:#f8f8fc;">
    <div class="container">
        <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:2rem;flex-wrap:wrap;gap:1rem;">
            <div>
                <h2 style="font-size:2rem;font-weight:800;color:#1a1a2e;margin-bottom:0.3rem;">Événements à venir</h2>
                <p style="color:#6b7280;margin:0;">Réservez votre place dès maintenant</p>
            </div>
            <a href="{{ path('app_events') }}" class="btn-outline-eventix">Voir tout →</a>
        </div>
        <div class="row g-4">
            {% for event in events|slice(0, 3) %}
            <div class="col-md-6 col-lg-4">
                <div class="event-card">
                    {% if event.image %}
                        <img src="{{ event.image }}" alt="{{ event.title }}" class="event-card-img">
                    {% else %}
                        <div class="event-card-img-placeholder"><i class="bi bi-calendar-event"></i></div>
                    {% endif %}
                    <div class="event-card-body">
                        <span class="event-badge"><i class="bi bi-calendar3 me-1"></i>{{ event.date|date('d M Y') }}</span>
                        <h3 class="event-title">{{ event.title }}</h3>
                        <p class="event-meta"><i class="bi bi-geo-alt-fill"></i>{{ event.location }}</p>
                        <p style="font-size:0.88rem;color:#6b7280;margin-bottom:1rem;line-height:1.6;">
                            {{ event.description|slice(0,100) }}{% if event.description|length > 100 %}...{% endif %}
                        </p>
                        <div style="display:flex;justify-content:space-between;align-items:center;">
                            {% set avail = event.availableSeats %}
                            <span class="seats-badge {{ avail <= 0 ? 'full' : (avail <= 5 ? 'low' : '') }}">
                                <i class="bi bi-ticket me-1"></i>{{ avail <= 0 ? 'Complet' : avail ~ ' places' }}
                            </span>
                            <a href="{{ path('app_event_show', {id: event.id}) }}" class="btn-primary-eventix" style="padding:0.45rem 1.2rem;font-size:0.85rem;">
                                Réserver
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# FEATURES #}
<section style="padding:5rem 0;background:#fff;">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <h2 style="font-size:2rem;font-weight:800;color:#1a1a2e;margin-bottom:1rem;">Shaping the Future<br>of Digital Innovation</h2>
                <p style="color:#4b5563;line-height:1.8;margin-bottom:2rem;">Notre plateforme connecte les participants avec les meilleurs événements. Réservez facilement et rejoignez une communauté de visionnaires.</p>
                <div class="row g-3">
                    <div class="col-6">
                        <div style="background:#f0f0f8;border-radius:12px;padding:1.25rem;">
                            <i class="bi bi-shield-check" style="font-size:1.5rem;color:#3b28cc;display:block;margin-bottom:0.5rem;"></i>
                            <div style="font-weight:700;font-size:0.95rem;margin-bottom:0.2rem;">Sécurisé</div>
                            <div style="font-size:0.82rem;color:#6b7280;">JWT + Passkeys</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div style="background:#f0f0f8;border-radius:12px;padding:1.25rem;">
                            <i class="bi bi-lightning-charge" style="font-size:1.5rem;color:#3b28cc;display:block;margin-bottom:0.5rem;"></i>
                            <div style="font-weight:700;font-size:0.95rem;margin-bottom:0.2rem;">Rapide</div>
                            <div style="font-size:0.82rem;color:#6b7280;">Réservation en 30s</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div style="background:#f0f0f8;border-radius:12px;padding:1.25rem;">
                            <i class="bi bi-phone" style="font-size:1.5rem;color:#3b28cc;display:block;margin-bottom:0.5rem;"></i>
                            <div style="font-weight:700;font-size:0.95rem;margin-bottom:0.2rem;">Responsive</div>
                            <div style="font-size:0.82rem;color:#6b7280;">Tous appareils</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div style="background:#f0f0f8;border-radius:12px;padding:1.25rem;">
                            <i class="bi bi-people" style="font-size:1.5rem;color:#3b28cc;display:block;margin-bottom:0.5rem;"></i>
                            <div style="font-weight:700;font-size:0.95rem;margin-bottom:0.2rem;">Communauté</div>
                            <div style="font-size:0.82rem;color:#6b7280;">Networking pro</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div style="background:linear-gradient(135deg,#3b28cc,#00b4d8);border-radius:20px;padding:3rem;color:#fff;text-align:center;">
                    <i class="bi bi-calendar-event" style="font-size:4rem;opacity:0.8;display:block;margin-bottom:1.5rem;"></i>
                    <h3 style="font-size:1.5rem;font-weight:700;margin-bottom:1rem;">{{ events|length }} événement{{ events|length > 1 ? 's' : '' }} disponible{{ events|length > 1 ? 's' : '' }}</h3>
                    <p style="opacity:0.85;font-size:0.95rem;margin-bottom:2rem;">Réservez votre place maintenant avant qu'il ne soit trop tard.</p>
                    <a href="{{ path('app_events') }}" class="btn-buy" style="font-size:0.9rem;padding:0.65rem 1.8rem;">
                        Découvrir tous les événements →
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}

{% block javascripts %}
{{ parent() }}
{% if events|length > 0 %}
<script>
const eventDate = new Date("{{ events[0].date|date('Y-m-d H:i:s') }}");
function updateCountdown() {
    const diff = eventDate - new Date();
    if (diff <= 0) {
        document.getElementById('countdown-wrap').innerHTML = '<span style="color:#6b7280;font-style:italic;">Événement en cours ou terminé</span>';
        return;
    }
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    document.getElementById('cd-days').textContent = String(d).padStart(2,'0');
    document.getElementById('cd-hours').textContent = String(h).padStart(2,'0');
    document.getElementById('cd-mins').textContent = String(m).padStart(2,'0');
    document.getElementById('cd-secs').textContent = String(s).padStart(2,'0');
}
updateCountdown();
setInterval(updateCountdown, 1000);
</script>
{% endif %}
{% endblock %}
