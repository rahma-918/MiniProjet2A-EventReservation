{% extends 'base.html.twig' %}

{% block title %}Inscription — Eventix{% endblock %}

{% block navbar %}{% endblock %}

{% block body %}
<div style="min-height:100vh;background:linear-gradient(135deg,#1a1a2e 0%,#3b28cc 60%,#00b4d8 100%);display:flex;align-items:center;justify-content:center;padding:2rem;">
    <div style="width:100%;max-width:440px;">

        <div style="text-align:center;margin-bottom:2rem;">
            <a href="{{ path('app_home') }}" style="display:inline-block;background:#fff;color:#3b28cc;font-weight:800;font-size:1.3rem;padding:0.5rem 1.3rem;border-radius:10px;text-decoration:none;margin-bottom:1.5rem;">
                Eventix
            </a>
            <h1 style="color:#fff;font-size:1.8rem;font-weight:800;margin-bottom:0.4rem;">Créer un compte</h1>
            <p style="color:rgba(255,255,255,0.7);font-size:0.95rem;">Rejoignez notre communauté</p>
        </div>

        <div style="background:#fff;border-radius:20px;padding:2.5rem;box-shadow:0 24px 64px rgba(0,0,0,0.2);">

            {# ======= SECTION PASSKEY (clé de sécurité uniquement) ======= #}
            <div style="background:linear-gradient(135deg,#F5F3FF 0%,#EEF0FF 100%);border:1px solid #C7D2FE;border-radius:12px;padding:1.2rem;margin-bottom:1.5rem;">
                <div style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#3b28cc;margin-bottom:0.5rem;">
                    🔑 Méthode recommandée
                </div>
                <div style="font-size:0.85rem;color:#4b5563;margin-bottom:0.75rem;">
                    Créez votre compte avec une <strong>clé de sécurité physique</strong> (ex: YubiKey) — plus sécurisé, aucun mot de passe à retenir.
                </div>
                <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:1rem;">
                    <span style="display:inline-flex;align-items:center;gap:0.3rem;font-size:0.75rem;color:#6b7280;">
                        <span style="width:6px;height:6px;background:#3b28cc;border-radius:50%;display:inline-block;"></span> Résistant au phishing
                    </span>
                    <span style="display:inline-flex;align-items:center;gap:0.3rem;font-size:0.75rem;color:#6b7280;">
                        <span style="width:6px;height:6px;background:#3b28cc;border-radius:50%;display:inline-block;"></span> Pas de mot de passe à mémoriser
                    </span>
                    <span style="display:inline-flex;align-items:center;gap:0.3rem;font-size:0.75rem;color:#6b7280;">
                        <span style="width:6px;height:6px;background:#3b28cc;border-radius:50%;display:inline-block;"></span> Standard FIDO2/WebAuthn
                    </span>
                </div>

                <button type="button" id="btn-passkey-register"
                        style="width:100%;background:#3b28cc;color:#fff;border:none;border-radius:8px;padding:0.75rem 1rem;font-weight:700;font-size:0.95rem;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:0.5rem;transition:background 0.2s;"
                        onmouseover="this.style.background='#2d1fa3'"
                        onmouseout="this.style.background='#3b28cc'">
                    <i class="bi bi-usb-symbol" style="font-size:1.1rem;"></i>
                    <span id="btn-passkey-text">S'inscrire avec une clé de sécurité</span>
                    <span class="spinner-passkey" style="display:none;width:16px;height:16px;border:2px solid rgba(255,255,255,0.4);border-top-color:#fff;border-radius:50%;animation:spin 0.6s linear infinite;"></span>
                </button>

                <div id="email-notice" style="display:none;background:#FFFBEB;border:1px solid #FDE68A;border-radius:8px;padding:0.5rem 0.75rem;font-size:0.82rem;color:#92400E;margin-top:0.75rem;">
                    ⚠️ Renseignez d'abord votre <strong>email</strong> dans le formulaire ci-dessous.
                </div>
            </div>

            {# Message de succès passkey #}
            <div id="passkey-success" style="display:none;background:#ECFDF5;border:1px solid #A7F3D0;border-radius:12px;padding:1rem;text-align:center;margin-bottom:1.5rem;">
                <div style="font-size:1.8rem;">✅</div>
                <div style="font-weight:700;color:#065F46;">Clé de sécurité enregistrée !</div>
                <div style="font-size:0.8rem;color:#047857;margin-top:0.25rem;">Vous pouvez maintenant vous connecter avec votre clé.</div>
            </div>

            <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;">
                <hr style="flex:1;border-color:#e5e7eb;">
                <span style="font-size:0.82rem;color:#9ca3af;white-space:nowrap;">ou s'inscrire avec mot de passe</span>
                <hr style="flex:1;border-color:#e5e7eb;">
            </div>

            {# ======= FORMULAIRE CLASSIQUE ======= #}
            {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

            <div class="mb-3">
                <label class="form-label">Nom d'utilisateur</label>
                <div style="position:relative;">
                    <i class="bi bi-person" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#6b7280;"></i>
                    {{ form_widget(form.username, {attr: {id: 'field-username', style: 'padding-left:2.5rem;', placeholder: 'Votre nom'}}) }}
                </div>
                {{ form_errors(form.username) }}
            </div>

            <div class="mb-3">
                <label class="form-label">Adresse email</label>
                <div style="position:relative;">
                    <i class="bi bi-envelope" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#6b7280;"></i>
                    {{ form_widget(form.email, {attr: {id: 'field-email', style: 'padding-left:2.5rem;', placeholder: 'votre@email.com'}}) }}
                </div>
                {{ form_errors(form.email) }}
            </div>

            <div class="mb-4">
                <label class="form-label">Mot de passe</label>
                <div style="position:relative;">
                    <i class="bi bi-lock" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#6b7280;"></i>
                    {{ form_widget(form.password, {attr: {style: 'padding-left:2.5rem;', placeholder: 'Min. 6 caractères'}}) }}
                </div>
                {{ form_errors(form.password) }}
            </div>

            <button type="submit" class="btn-primary-eventix" style="width:100%;border:none;text-align:center;font-size:1rem;">
                <i class="bi bi-person-plus me-2"></i>Créer mon compte
            </button>

            {{ form_end(form) }}

            <div style="text-align:center;margin-top:2rem;padding-top:1.5rem;border-top:1px solid #f0f0f8;">
                <span style="color:#6b7280;font-size:0.9rem;">Déjà inscrit ?</span>
                <a href="{{ path('app_login') }}" style="color:#3b28cc;font-weight:700;text-decoration:none;margin-left:0.4rem;font-size:0.9rem;">Se connecter →</a>
            </div>
            <div style="margin-top:0.75rem;text-align:center;">
                <a href="{{ path('app_home') }}" style="color:#9ca3af;font-size:0.85rem;text-decoration:none;">
                    <i class="bi bi-arrow-left me-1"></i>Retour à l'accueil
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="{{ asset('js/auth.js') }}"></script>
<style>
    @keyframes spin { to { transform: rotate(360deg); } }
</style>
<script>
document.addEventListener('DOMContentLoaded', function () {

    const btn          = document.getElementById('btn-passkey-register');
    const btnText      = document.getElementById('btn-passkey-text');
    const spinner      = document.querySelector('.spinner-passkey');
    const emailNotice  = document.getElementById('email-notice');
    const successBox   = document.getElementById('passkey-success');
    const emailInput   = document.getElementById('field-email')
                      || document.querySelector('input[type="email"]');
    const usernameInput = document.getElementById('field-username');

    function setLoading(on) {
        btn.disabled      = on;
        spinner.style.display = on ? 'inline-block' : 'none';
        btnText.style.opacity = on ? '0.7' : '1';
    }

    async function handlePasskeyRegister() {
        const email       = emailInput ? emailInput.value.trim() : '';
        const displayName = usernameInput ? usernameInput.value.trim() : '';

        // Validation email
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            emailNotice.style.display = 'block';
            emailNotice.textContent   = '⚠️ Renseignez une adresse email valide ci-dessous avant de continuer.';
            if (emailInput) { emailInput.focus(); emailInput.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
            return;
        }
        emailNotice.style.display = 'none';

        // Vérifier support WebAuthn
        if (!window.PublicKeyCredential) {
            alert("Votre navigateur ne supporte pas WebAuthn / les clés de sécurité.");
            return;
        }

        setLoading(true);
        try {
            const result = await registerPasskey(email, displayName || email.split('@')[0]);
            if (result && result.token) {
                successBox.style.display = 'block';
                btn.style.background     = '#0D9E6E';
                btnText.textContent      = '✓ Clé enregistrée !';
                setTimeout(() => { window.location.href = '/'; }, 2000);
            } else {
                setLoading(false);
            }
        } catch (err) {
            console.error('Passkey register error:', err);
            setLoading(false);
        }
    }

    if (btn) btn.addEventListener('click', handlePasskeyRegister);
    if (emailInput) {
        emailInput.addEventListener('input', () => {
            if (emailInput.value.trim()) emailNotice.style.display = 'none';
        });
    }
});
</script>
{% endblock %}
